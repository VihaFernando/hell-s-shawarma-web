# Instagram Graph API (Business Discovery) — used by netlify/functions/instagram.js
# and netlify/functions/instagram-refresh-token*.js

# The Instagram Business Account ID whose linked Facebook app/token performs the
# Business Discovery lookup (does NOT have to be the client's own account).
IG_BUSINESS_ACCOUNT_ID=

# Long-lived Instagram/Facebook Graph API access token (~60 day expiry).
# Auto-refreshed monthly by the scheduled function and stored in Netlify Blobs;
# this env var is only the initial/fallback value.
IG_LONG_LIVED_TOKEN=

# Facebook App ID + Secret, used to exchange/refresh the long-lived token.
IG_APP_ID=
IG_APP_SECRET=

# The client's public Instagram username to fetch posts for via Business Discovery.
CLIENT_IG_USERNAME=

# Google Places API (New) — used by netlify/functions/reviews.js

# API key with the Places API (New) enabled.
GOOGLE_PLACES_API_KEY=

# The business's Google Place ID (not secret — also used to build the public
# "view all reviews" link).
GOOGLE_PLACE_ID=

# Your site's origin (e.g. https://hells-shawarma-and-grill.netlify.app or a
# custom domain), used to reject requests to /api/reviews whose Origin/Referer
# doesn't match — stops the endpoint being scraped/hotlinked from other sites.
ALLOWED_ORIGIN=
